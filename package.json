{
  "name": "mermaid-validator-mcp",
  "version": "1.0.1",
  "description": "MCP server for validating Mermaid diagram syntax",
  "type": "module",
  "author": "LF112(futiwolf) <lf@lf112.net>",
  "license": "MIT",
  "homepage": "https://github.com/LF112/mermaid-validator-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LF112/mermaid-validator-mcp.git"
  },
  "keywords": [
    "mcp",
